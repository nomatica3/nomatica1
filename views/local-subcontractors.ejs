<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Local Subcontractors</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { font-family: Arial, sans-serif; margin: 2rem; background: #f9f9f9; }
        h1 { color: #333; }
        table { width: 100%; border-collapse: collapse; margin-top: 1rem; background: #fff; }
        th, td { padding: 0.75rem; border: 1px solid #ddd; text-align: left; }
        th { background: #f0f0f0; }
        tr:nth-child(even) { background: #f7f7f7; }
        .add-btn { margin-top: 1rem; padding: 0.5rem 1rem; background: #007bff; color: #fff; border: none; border-radius: 4px; cursor: pointer; }
        .add-btn:hover { background: #0056b3; }
    </style>
</head>
<body>
    <h1>Local Subcontractors</h1>
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Specialty</th>
                <th>Contact</th>
                <th>Location</th>
            </tr>
        </thead>
        <tbody>
            <% if (subcontractors && subcontractors.length > 0) { %>
                <% subcontractors.forEach(function(sub) { %>
                    <tr>
                        <td><%= sub.name %></td>
                        <td><%= sub.specialty %></td>
                        <td><%= sub.contact %></td>
                        <td><%= sub.location %></td>
                    </tr>
                <% }); %>
            <% } else { %>
                <tr>
                    <td colspan="4">No subcontractors found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
    <form action="/local-subcontractors/add" method="POST">
        <button class="add-btn" type="submit">Add Subcontractor</button>
    </form>
</body>
</html></html>