<footer class="fixed-footer">
  <div class="footer-content container-fluid d-flex justify-content-between align-items-center">
    <span class="footer-copyright">
      &copy; <%= new Date().getFullYear() %> Colorful Moves. All rights reserved.
    </span>
    <!-- Toggle Button -->
<button id="chat-toggle" class="btn btn-outline-primary btn-sm">
  💬 Chat AI
</button>

<!-- Chat Widget -->
<div id="chat-widget" class="card text-dark" style="display: none; position: fixed; bottom: 60px; right: 20px; width: 300px; z-index: 9999;">
  <div id="chat-header" class="card-header d-flex justify-content-between align-items-center">
    <span>Chat AI Assistant</span>
    <button id="chat-close" class="btn btn-sm btn-light">&times;</button>
  </div>
  <div id="chat-messages" class="card-body" style="max-height: 300px; overflow-y: auto;"></div>
  <form id="chat-form" class="p-2 border-top" autocomplete="off">
    <input type="text" id="chat-input" class="form-control mb-2" placeholder="Ask me something..." required>
    <button type="submit" class="btn btn-primary w-100">Send</button>
  </form>
</div>

    <span class="footer-links">
      <a href="/privacy-policy">Privacy Policy</a> |
      <a href="/terms-of-service">Terms of Service</a>
    </span>
  </div>



