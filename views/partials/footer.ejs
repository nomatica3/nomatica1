<footer class="fixed-footer">
  <div class="footer-content container-fluid d-flex justify-content-between align-items-center">
    <span class="footer-copyright">
      &copy; <%= new Date().getFullYear() %> Colorful Moves. All rights reserved.
    </span>
    <button id="chat-toggle" class="btn btn-outline-primary btn-sm">
      💬 Chat AI
    </button>
    <span class="footer-links">
      <a href="/privacy-policy">Privacy Policy</a> |
      <a href="/terms-of-service">Terms of Service</a>
    </span>
  </div>
  <!-- Chat Widget -->
<div id="chat-widget">
  <div id="chat-header">
    <span>Chat AI Assistant</span>
    <button id="chat-close">&times;</button>
  </div>
  <div id="chat-messages"></div>
  <form id="chat-form" autocomplete="off">
    <input type="text" id="chat-input" placeholder="Ask me something..." required/>
    <button type="submit">Send</button>
  </form>
</div>
</footer>


