<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <!-- Sidebar -->
  <div class="sidebar-menu">
    <ul class="nav flex-column">
      <li class="nav-item"><a class="nav-link" href="/new-chat">📝 New Chat</a></li>
      <li class="nav-item"><a class="nav-link" href="/search-chats">🔍 Search Chats</a></li>
      <li class="nav-item"><a class="nav-link" href="/library">📚 Library</a></li>
      <li class="nav-item"><a class="nav-link" href="/images">🖼️ Images</a></li>
      <li class="nav-item"><a class="nav-link" href="/videos">🎥 Videos</a></li>
      <li class="nav-item"><a class="nav-link" href="/explore">🌐 Explore</a></li>
      <li class="nav-item"><a class="nav-link" href="/">💬 CAPS Chat</a></li>
      <li class="nav-item"><a class="nav-link" href="/settings">⚙️ Settings</a></li>
      <li class="nav-item"><a class="nav-link" href="/help">❓ Help</a></li>
      <li class="nav-item"><a class="nav-link" href="/about">ℹ️ About</a></li>
    </ul>
  </div>

  <!-- Header -->
  <header class="main-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
      <h1 class="h4 my-2">Colorful Moves</h1>
      <div class="dropdown">
        <button class="btn btn-link dropdown-toggle" type="button" data-bs-toggle="dropdown">
          Menu
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><a class="dropdown-item" href="/find-contracts">Find Contracts</a></li>
          <li><a class="dropdown-item" href="/submit-proposal">Submit Proposal</a></li>
          <li><a class="dropdown-item" href="/local-subcontractors">Local Subcontractors</a></li>
          <li><hr class="dropdown-divider" /></li>
          <li><a class="dropdown-item" href="/vendor-portal">Vendor Portal</a></li>
          <li><a class="dropdown-item" href="/admin-portal">Admin Portal</a></li>
        </ul>
      </div>
    </div>
  </header>

  <!-- Main content area -->
  <main class="main-content container py-4">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="simple-footer">
    <div class="footer-content">
      <span>&copy; 2025 Colorful Moves. All rights reserved.</span>
      <form id="chatForm" class="d-flex align-items-center">
        <input type="text" class="form-control me-2" placeholder="Ask CAPS to automate something..." />
        <button type="submit" class="btn btn-primary">Ask</button>
      </form>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/script.js"></script>
</body>
</html>
