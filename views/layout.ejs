<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Colorful Moves</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      margin: 0;
      font-family: system-ui, sans-serif;
      background-color: #f8f9fa;
      min-height: 100vh;
      padding-left: 220px; /* Reserve space for sidebar */
      display: flex;
      flex-direction: column;
    }
    #sidebarMenu.hidden {
      margin-left: -220px;
    }
    .main-content {
      padding: 1.5rem;
      flex: 1;
    }
    .navbar-container,
    .footer-container {
      max-width: calc(100% - 220px);
      margin-left: 220px;
      background: #fff;
      border-bottom: 1px solid #ddd;
    }
    .footer-container {
      border-top: 1px solid #ddd;
    }
    .navbar {
      background-color: #ffffff;
    }
    .footer {
      padding: 0.75rem;
      text-align: center;
    }
    @media (max-width: 768px) {
      body {
        padding-left: 0;
      }
      .navbar-container,
      .footer-container {
        max-width: 100%;
        margin-left: 0;
      }
    }
  </style>
</head>
<body>

  <!-- Sidebar -->
  <nav id="sidebarMenu" class="bg-light border-end position-fixed h-100 p-3" style="width:220px; top:4rem; left:0; transition:margin 0.3s;">
    <ul class="nav flex-column">
      <li class="nav-item"><a class="nav-link" href="/new-chat">📝 New Chat</a></li>
      <li class="nav-item"><a class="nav-link" href="/search-chats">🔍 Search Chats</a></li>
      <li class="nav-item"><a class="nav-link" href="/library">📚 Library</a></li>
      <li class="nav-item"><a class="nav-link" href="/images">🖼️ Images</a></li>
      <li class="nav-item"><a class="nav-link" href="/videos">🎥 Videos</a></li>
      <li class="nav-item"><a class="nav-link" href="/explore">🌐 Explore</a></li>
      <li class="nav-item"><a class="nav-link" href="/">💬 CAPS Chat</a></li>
      <li class="nav-item"><a class="nav-link" href="/settings">⚙️ Settings</a></li>
      <li class="nav-item"><a class="nav-link" href="/help">❓ Help</a></li>
      <li class="nav-item"><a class="nav-link" href="/about">ℹ️ About</a></li>
    </ul>
  </nav>

  <!-- Header/Navbar -->
  <div class="navbar-container">
    <nav class="navbar navbar-expand-lg border-bottom">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/">Colorful Moves</a>
        <button id="sidebarToggle" class="btn btn-outline-secondary" aria-label="Toggle sidebar">☰</button>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="navbarNavDropdown">
          <ul class="navbar-nav">
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                Menu
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/find-contracts">Find Contracts</a></li>
                <li><a class="dropdown-item" href="/submit-proposal">Submit Proposal</a></li>
                <li><a class="dropdown-item" href="/local-subcontractors">Local Subcontractors</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="/vendor-portal">Vendor Portal</a></li>
                <li><a class="dropdown-item" href="/admin-portal">Admin Portal</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </div>

  <!-- Main Content -->
  <main class="main-content">
    <h1>Welcome to our platform</h1>
    <p>An AI-driven platform used for custom automations.</p>
    <form class="d-flex justify-content-center">
      <input type="text" class="form-control w-50 me-2" placeholder="Ask Anything..." />
      <button type="submit" class="btn btn-primary">Ask</button>
    </form>
  </main>

  <!-- Footer -->
  <div class="footer-container">
    <footer class="footer">
      <span class="text-muted">&copy; 2025 Colorful Moves. All rights reserved.</span>
      <span class="ms-2">
        <a href="/privacy" class="text-muted me-2">Privacy Policy</a> |
        <a href="/terms" class="text-muted ms-2">Terms of Service</a>
      </span>
    </footer>
  </div>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const sidebar = document.getElementById('sidebarMenu');
      const toggleBtn = document.getElementById('sidebarToggle');
      toggleBtn.addEventListener('click', () => {
        sidebar.classList.toggle('hidden');
        document.body.style.paddingLeft = sidebar.classList.contains('hidden') ? '0' : '220px';
        document.querySelector('.navbar-container').style.marginLeft = sidebar.classList.contains('hidden') ? '0' : '220px';
        document.querySelector('.footer-container').style.marginLeft = sidebar.classList.contains('hidden') ? '0' : '220px';
      });
    });
  </script>
</body>
</html>
