<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/styles.css"/>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body class="d-flex">

<!-- Sidebar -->
<nav class="sidebar d-flex flex-column flex-shrink-0 p-3 bg-light border-end" style="width: 240px; height: 100vh; position: fixed;">
  <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-decoration-none">
    <span class="fs-4 fw-bold">Colorful Moves</span>
  </a>
  <hr>
  <ul class="nav nav-pills flex-column mb-auto">
    <li><a href="/new-chat" class="nav-link link-dark">📝 New Chat</a></li>
    <li><a href="/search-chats" class="nav-link link-dark">🔍 Search Chats</a></li>
    <li><a href="/library" class="nav-link link-dark">📚 Library</a></li>
    <li><a href="/images" class="nav-link link-dark">🖼️ Images</a></li>
    <li><a href="/videos" class="nav-link link-dark">🎥 Videos</a></li>
    <li><a href="/explore" class="nav-link link-dark">🌐 Explore</a></li>
    <li><a href="/" class="nav-link link-dark">💬 CAPS Chat</a></li>
    <li><a href="/settings" class="nav-link link-dark">⚙️ Settings</a></li>
    <li><a href="/help" class="nav-link link-dark">❓ Help</a></li>
    <li><a href="/about" class="nav-link link-dark">ℹ️ About</a></li>
  </ul>
</nav>

<!-- Page container -->
<div class="flex-grow-1" style="margin-left:240px;">
  <!-- Fixed Header -->
  <header class="navbar navbar-light bg-white border-bottom shadow-sm fixed-top" style="left:240px; right:0;">
    <div class="container-fluid">
      <button class="navbar-toggler d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu">
        <span class="navbar-toggler-icon"></span>
      </button>
      <ul class="navbar-nav ms-auto flex-row">
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
            Menu
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/find-contracts">Find Contracts</a></li>
            <li><a class="dropdown-item" href="/submit-proposal">Submit Proposal</a></li>
            <li><a class="dropdown-item" href="/local-subcontractors">Local Subcontractors</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/vendor-portal">Vendor Portal</a></li>
            <li><a class="dropdown-item" href="/admin-portal">Admin Portal</a></li>
          </ul>
        </li>
      </ul>
    </div>
  </header>

  <!-- Main Content -->
  <main class="pt-5" style="padding-top:70px; padding-bottom:60px;">
    <div class="container-fluid">
      <%- body %>
    </div>
  </main>

  <!-- Footer -->
  <footer class="footer bg-light border-top py-2 fixed-bottom" style="left:240px; right:0;">
    <div class="container d-flex justify-content-between align-items-center">
      <small>&copy; 2025 Colorful Moves. All rights reserved.</small>
      <form class="d-flex">
        <input type="text" placeholder="Ask CAPS..." class="form-control form-control-sm me-2"/>
        <button class="btn btn-primary btn-sm">Ask</button>
      </form>
    </div>
  </footer>
</div>

</body>
</html>
