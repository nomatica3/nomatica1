<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> | Colorful Moves</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
  <style>
    body {
      padding-left: 220px; /* Reserve space for sidebar */
      min-height: 100vh;
    }
    #sidebarMenu.hidden {
      margin-left: -240px;
    }
    .main-content {
      transition: margin-left 0.3s;
    }
  </style>
</head>
<body class="d-flex flex-column min-vh-100">
  <!-- Header / Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top shadow-sm">
  <div class="container-fluid px-4">
    <button id="sidebarToggle" class="btn btn-outline-light me-2 position-absolute start-0 ms-2">☰</button>
    <a class="navbar-brand fw-bold mx-auto" href="/">Colorful Moves</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse justify-content-end" id="navbarNavDropdown">
      <ul class="navbar-nav">
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="mainDropdown" role="button" data-bs-toggle="dropdown">
            Menu
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/find-contracts">Find Contracts</a></li>
            <li><a class="dropdown-item" href="/submit-proposal">Submit Proposal</a></li>
            <li><a class="dropdown-item" href="/local-subcontractors">Local Subcontractors</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/vendor-portal">Vendor Portal</a></li>
            <li><a class="dropdown-item" href="/admin-portal">Admin Portal</a></li>
          </ul>
        </li>
      </ul>
    </div>
  </div>
</nav>

<!-- Sidebar -->
<nav id="sidebarMenu" class="bg-dark text-white position-fixed h-100 p-3" style="width:220px; top:56px; left:0; transition:margin 0.3s;">
  <ul class="nav flex-column">
    <li class="nav-item"><a class="nav-link text-white" href="/new-chat">📝 New Chat</a></li>
    <li class="nav-item"><a class="nav-link text-white" href="/search-chats">🔍 Search Chats</a></li>
    <li class="nav-item"><a class="nav-link text-white" href="/library">📚 Library</a></li>
    <li class="nav-item"><a class="nav-link text-white" href="/images">🖼️ Images</a></li>
    <li class="nav-item"><a class="nav-link text-white" href="/videos">🎥 Videos</a></li>
    <li class="nav-item"><a class="nav-link text-white" href="/explore">🌐 Explore</a></li>
    <li class="nav-item"><a class="nav-link text-white" href="/">💬 CAPS Chat</a></li>
    <li class="nav-item"><a class="nav-link text-white" href="/settings">⚙️ Settings</a></li>
    <li class="nav-item"><a class="nav-link text-white" href="/help">❓ Help</a></li>
    <li class="nav-item"><a class="nav-link text-white" href="/about">ℹ️ About</a></li>
  </ul>
</nav>


  <!-- Main Content -->
  <main class="main-content p-4 mt-5 flex-fill">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="footer text-center mt-auto py-3 bg-light border-top">
    <div class="container-fluid d-flex justify-content-between align-items-center px-4">
      <span class="text-muted">&copy; 2025 Colorful Moves. All rights reserved.</span>
      <span>
        <a href="/privacy" class="text-muted me-2">Privacy Policy</a> |
        <a href="/terms" class="text-muted ms-2">Terms of Service</a>
      </span>
    </div>
  </footer>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const sidebar = document.getElementById('sidebarMenu');
      const toggleBtn = document.getElementById('sidebarToggle');
      if (toggleBtn && sidebar) {
        toggleBtn.addEventListener('click', () => {
          sidebar.classList.toggle('hidden');
          document.body.style.paddingLeft = sidebar.classList.contains('hidden') ? '0' : '220px';
        });
      }
    });
  </script>
  <script src="/script.js"></script>
</body>
</html>
