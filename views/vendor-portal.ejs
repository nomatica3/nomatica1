<!DOCTYPE html>
<html lang="en">
<head>
    <% include('partials/head') %>
    <title>Vendor Portal</title>
    <style>
        .workspace-card { background: #f8f9fa; border-radius: 10px; padding: 1.5rem; margin-bottom: 1.5rem; }
    </style>
</head>
<body>
    <% include('partials/navbar') %>
    <div class="container py-4">
        <h1>Vendor Portal Workspace</h1>
        <div class="workspace-card">
            <h4>Submit Documentation</h4>
            <form>
                <input type="file" class="form-control mb-2" />
                <input type="text" class="form-control mb-2" placeholder="License Number" />
                <textarea class="form-control mb-2" placeholder="Updates or Notes"></textarea>
                <button class="btn btn-primary">Upload</button>
            </form>
        </div>
        <div class="workspace-card">
            <h4>Photo Gallery</h4>
            <!-- Thumbnails of uploaded photos -->
        </div>
        <div class="workspace-card">
            <h4>Recent Updates</h4>
            <!-- List of updates -->
        </div>
    </div>
    <% include('partials/footer') %>
</body>
</html>