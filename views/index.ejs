<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Colorful Moves</title>
    <!-- Use Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <style>
        body {
            background: #fff;
            color: #181a1b;
            min-height: 100vh;
        }
        .navbar, .fixed-footer {
            background: #f8f9fa !important;
        }
        .navbar-brand, .nav-link, .dropdown-item, .navbar-toggler-icon {
            color: #181a1b !important;
        }
        .nav-link.active, .nav-link:focus, .nav-link:hover {
            color: #4a90e2 !important;
        }
        .dropdown-menu {
            background: #fff;
        }
        .dropdown-item:hover, .dropdown-item:focus {
            background: #f1f1f1;
            color: #4a90e2;
        }
        .center-section {
            text-align: center;
        }
        .card {
            background: #fff;
            color: #181a1b;
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        }
        .form-control, .form-control:focus {
            background: #fff;
            color: #181a1b;
            border: 1px solid #dee2e6;
        }
        .btn-primary, .btn-success, .btn-outline-primary, .btn-outline-secondary {
            border-radius: 6px;
        }
        .btn-primary, .btn-success {
            background: #4a90e2;
            border-color: #4a90e2;
        }
        .btn-primary:hover, .btn-success:hover {
            background: #357ab7;
            border-color: #357ab7;
        }
        .btn-outline-primary, .btn-outline-secondary {
            color: #4a90e2;
            border-color: #4a90e2;
            background: transparent;
        }
        .btn-outline-primary:hover, .btn-outline-secondary:hover {
            background: #4a90e2;
            color: #fff;
        }
        .nav-tabs .nav-link.active {
            background: #fff;
            color: #4a90e2 !important;
            border-color: #4a90e2 #fff #fff;
        }
        .nav-tabs .nav-link {
            color: #181a1b;
        }
        .tab-content {
            background: #fff;
            color: #181a1b;
        }
        .fixed-footer {
            position: fixed;
            left: 0;
            bottom: 0;
            width: 100%;
            z-index: 1030;
            box-shadow: 0 -2px 8px rgba(0,0,0,0.08);
        }
        #chat-assistant-container {
            max-width: 400px;
            margin: 0 auto;
        }
        #chat-assistant {
            background: #f8f9fa;
            color: #181a1b;
            border-radius: 8px;
            padding: 10px;
            margin-top: 10px;
            max-height: 200px;
            overflow-y: auto;
        }
        #chat-messages {
            max-height: 100px;
            overflow-y: auto;
            margin-bottom: 8px;
        }
        .chat-message.user { color: #4a90e2; }
        .chat-message.ai { color: #181a1b; }
        .spinner {
            display: inline-block;
            width: 24px;
            height: 24px;
            border: 3px solid #dee2e6;
            border-top: 3px solid #4a90e2;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-left: 10px;
            vertical-align: middle;
        }
        @keyframes spin {
            0% { transform: rotate(0deg);}
            100% { transform: rotate(360deg);}
        }
        .hidden { display: none; }
        .section-highlight {
            animation: highlight 1s;
            box-shadow: 0 0 10px 2px #4a90e2;
        }
        @keyframes highlight {
            0% { box-shadow: 0 0 0 0 #4a90e2; }
            100% { box-shadow: 0 0 10px 2px #4a90e2; }
        }
    </style>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <!-- Navbar with Dropdown Menu -->
    <nav class="navbar navbar-expand-lg navbar-light mb-4">
        <div class="container-fluid">
            <a class="navbar-brand mx-auto" href="#">Colorful Moves</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-center" id="navbarNavDropdown">
                <ul class="navbar-nav center-links">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="mainDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Menu
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="mainDropdown">
                            <li><a class="dropdown-item nav-scroll" href="#find-contracts" data-target="#find-contracts">Find Contracts</a></li>
                            <li><a class="dropdown-item nav-scroll" href="#submit-proposal" data-target="#submit-proposal">Submit Proposal</a></li>
                            <li><a class="dropdown-item nav-scroll" href="#local-subcontractors" data-target="#local-subcontractors">Local Subcontractors</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item portal-tab-link" href="#" data-tab="vendor">Vendor Portal</a></li>
                            <li><a class="dropdown-item portal-tab-link" href="#" data-tab="admin">Admin Portal</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</body>
</html>