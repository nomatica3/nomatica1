<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Colorful Moves</title>
    <!-- Use Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <style>
    body {
        background: #fff;
        color: #181a1b;
        min-height: 100vh;
    }
    .navbar, .fixed-footer {
        background: #f8f9fa !important;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .navbar-brand {
        color: #181a1b !important;
        font-weight: bold;
        margin-right: 2rem;
        margin-left: 0 !important;
    }
    .navbar-nav .nav-link, .dropdown-item, .navbar-toggler-icon {
        color: #181a1b !important;
    }
    .nav-link.active, .nav-link:focus, .nav-link:hover {
        color: #4a90e2 !important;
    }
    .dropdown-menu {
        background: #fff;
    }
    .dropdown-item:hover, .dropdown-item:focus {
        background: #f1f1f1;
        color: #4a90e2;
    }
    .fixed-footer {
        position: fixed;
        left: 0;
        bottom: 0;
        width: 100%;
        z-index: 1030;
        box-shadow: 0 -2px 8px rgba(0,0,0,0.08);
        padding: 0;
    }
    .footer-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 60px;
        padding: 0 2rem;
        width: 100%;
    }
    .footer-copyright {
        color: #181a1b;
        font-size: 1rem;
        white-space: nowrap;
    }
    #chat-footer-assistant {
        display: flex;
        align-items: center;
        margin-left: auto;
    }
    #chat-assistant {
        background: #f8f9fa;
        color: #181a1b;
        border-radius: 8px;
        padding: 10px;
        margin-left: 1rem;
        max-width: 320px;
        min-width: 220px;
        max-height: 200px;
        overflow-y: auto;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        display: none;
        position: absolute;
        bottom: 70px;
        right: 2rem;
    }
    #chat-messages {
        max-height: 100px;
        overflow-y: auto;
        margin-bottom: 8px;
    }
    .chat-message.user { color: #4a90e2; }
    .chat-message.ai { color: #181a1b; }
    .spinner {
        display: inline-block;
        width: 24px;
        height: 24px;
        border: 3px solid #dee2e6;
        border-top: 3px solid #4a90e2;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-left: 10px;
        vertical-align: middle;
    }
    .hidden { display: none; }
    @media (max-width: 991.98px) {
        .navbar .container-fluid {
            flex-direction: column;
            align-items: flex-start !important;
        }
        .navbar-brand {
            margin-right: 0;
            margin-bottom: 0.25rem;
            margin-left: 0 !important;
        }
        .navbar-collapse {
            width: 100%;
        }
        .navbar-nav {
            width: 100%;
            justify-content: flex-start !important;
        }
        .footer-content {
            flex-direction: column;
            align-items: stretch;
            height: auto;
            padding: 1rem 1rem 0.5rem 1rem;
        }
        #chat-footer-assistant {
            margin-left: 0;
            margin-top: 0.5rem;
            justify-content: flex-end;
            width: 100%;
        }
        #chat-assistant {
            right: 1rem;
            left: 1rem;
            max-width: 95vw;
        }
    }
    @media (max-width: 575.98px) {
        .footer-content {
            padding: 0.5rem 0.5rem 0.25rem 0.5rem;
        }
        .navbar-brand {
            font-size: 1.25rem;
        }
    }
</style>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <!-- Navbar with Dropdown Menu -->
    <nav class="navbar navbar-expand-lg navbar-light mb-4">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="#">Colorful Moves</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNavDropdown">
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="mainDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Menu
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="mainDropdown">
                            <li><a class="dropdown-item nav-scroll" href="#find-contracts" data-target="#find-contracts">Find Contracts</a></li>
                            <li><a class="dropdown-item nav-scroll" href="#submit-proposal" data-target="#submit-proposal">Submit Proposal</a></li>
                            <li><a class="dropdown-item nav-scroll" href="#local-subcontractors" data-target="#local-subcontractors">Local Subcontractors</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item portal-tab-link" href="#" data-tab="vendor">Vendor Portal</a></li>
                            <li><a class="dropdown-item portal-tab-link" href="#" data-tab="admin">Admin Portal</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Footer fixed at bottom -->
    <footer class="fixed-footer">
        <div class="footer-content position-relative">
            <span class="footer-copyright">&copy; 2025 Colorful Moves. All rights reserved.</span>
            <div id="chat-footer-assistant">
                <button id="chat-toggle" class="btn btn-outline-primary btn-sm">Chat AI</button>
                <div id="chat-assistant">
                    <div id="chat-messages" class="mb-2"></div>
                    <form id="chat-form" autocomplete="off" class="d-flex">
                        <input type="text" id="chat-input" class="form-control me-2" placeholder="Ask me anything..." required />
                        <button type="submit" id="chat-send" class="btn btn-primary">Send</button>
                        <span id="chat-spinner" class="spinner hidden"></span>
                    </form>
                </div>
            </div>
        </div>
    </footer>
    <script>
        // Toggle chat assistant visibility
        $('#chat-toggle').on('click', function() {
            $('#chat-assistant').toggle();
        });

        // Chat AI Assistant with loading spinner
        $('#chat-form').on('submit', function(e) {
            e.preventDefault();
            const userMsg = $('#chat-input').val().trim();
            if (!userMsg) return;
            $('#chat-messages').append('<div class="chat-message user">You: ' + $('<div>').text(userMsg).html() + '</div>');
            $('#chat-input').val('');
            $('#chat-messages').scrollTop($('#chat-messages')[0].scrollHeight);
            $('#chat-spinner').removeClass('hidden');

            setTimeout(function() {
                let aiResponse = "I'm your AI assistant. How can I help you?";
                if (/contract|proposal|subcontractor|vendor|admin/i.test(userMsg)) {
                    aiResponse = "Let me help you with information about " + userMsg + ".";
                }
                $('#chat-messages').append('<div class="chat-message ai">AI: ' + $('<div>').text(aiResponse).html() + '</div>');
                $('#chat-messages').scrollTop($('#chat-messages')[0].scrollHeight);
                $('#chat-spinner').addClass('hidden');
            }, 700);
        });

        // Hide chat on click outside
        $(document).on('mousedown touchstart', function(e) {
            if (
                $('#chat-assistant').is(':visible') &&
                !$(e.target).closest('#chat-assistant, #chat-toggle').length
            ) {
                $('#chat-assistant').hide();
            }
        });
    </script>
</body>
</html>