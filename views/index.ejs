<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title><%= title || 'Custom AI Automations' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container py-4 text-center">
  <h1>Custom AI Automations</h1>
  <!--p></p-->

  <div class="chat-box mt-4 mx-auto" style="max-width:500px;">
    <input
      type="text"
      id="userMessage"
      class="form-control"
      placeholder="Ask or Customize Anything..."
    />
    <button class="btn btn-primary mt-2" onclick="sendToCAPS()">Ask</button>
    <div id="chatResponse" class="mt-3 text-start"></div>
  </div>
</div>

<script>
async function sendToCAPS() {
  const userMessageEl = document.getElementById('userMessage');
  const chatResponseEl = document.getElementById('chatResponse');
  const userMessage = userMessageEl.value;

  if (!userMessage.trim()) return;

  chatResponseEl.innerText = 'Thinking...';

  try {
    const res = await fetch('/api/openai', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: userMessage })
    });

    const data = await res.json();

    if (!res.ok) {
      throw new Error(data.error || 'Error contacting AI.');
    }

    chatResponseEl.innerText = data.response || data.reply || 'No response.';
  } catch (err) {
    console.error('Chat error:', err);
    chatResponseEl.innerText = err.message || 'Error contacting AI.';
  }
}

document.getElementById('userMessage').addEventListener('keydown', (event) => {
  if (event.key === 'Enter') {
    event.preventDefault();
    sendToCAPS();
  }
});
</script>
</body>
</html>
