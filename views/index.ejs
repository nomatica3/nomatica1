<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Colorful Moves</title>
    <!-- Use Bootstrap dark theme -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <style>
        body {
            background: #181a1b;
            color: #f8f9fa;
            min-height: 100vh;
        }
        .navbar, .fixed-footer {
            background: #212529 !important;
        }
        .navbar-brand, .nav-link, .dropdown-item, .navbar-toggler-icon {
            color: #f8f9fa !important;
        }
        .nav-link.active, .nav-link:focus, .nav-link:hover {
            color: #4a90e2 !important;
        }
        .dropdown-menu {
            background: #23272b;
        }
        .dropdown-item:hover, .dropdown-item:focus {
            background: #343a40;
            color: #4a90e2;
        }
        .center-section {
            text-align: center;
        }
        .card {
            background: #23272b;
            color: #f8f9fa;
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.18);
        }
        .form-control, .form-control:focus {
            background: #23272b;
            color: #f8f9fa;
            border: 1px solid #343a40;
        }
        .btn-primary, .btn-success, .btn-outline-primary, .btn-outline-secondary {
            border-radius: 6px;
        }
        .btn-primary, .btn-success {
            background: #4a90e2;
            border-color: #4a90e2;
        }
        .btn-primary:hover, .btn-success:hover {
            background: #357ab7;
            border-color: #357ab7;
        }
        .btn-outline-primary, .btn-outline-secondary {
            color: #4a90e2;
            border-color: #4a90e2;
            background: transparent;
        }
        .btn-outline-primary:hover, .btn-outline-secondary:hover {
            background: #4a90e2;
            color: #fff;
        }
        .nav-tabs .nav-link.active {
            background: #23272b;
            color: #4a90e2 !important;
            border-color: #4a90e2 #23272b #23272b;
        }
        .nav-tabs .nav-link {
            color: #f8f9fa;
        }
        .tab-content {
            background: #23272b;
            color: #f8f9fa;
        }
        .fixed-footer {
            position: fixed;
            left: 0;
            bottom: 0;
            width: 100%;
            z-index: 1030;
            box-shadow: 0 -2px 8px rgba(0,0,0,0.2);
        }
        #chat-assistant-container {
            max-width: 400px;
            margin: 0 auto;
        }
        #chat-assistant {
            background: #23272b;
            color: #f8f9fa;
            border-radius: 8px;
            padding: 10px;
            margin-top: 10px;
            max-height: 200px;
            overflow-y: auto;
        }
        #chat-messages {
            max-height: 100px;
            overflow-y: auto;
            margin-bottom: 8px;
        }
        .chat-message.user { color: #4a90e2; }
        .chat-message.ai { color: #fff; }
        .spinner {
            display: inline-block;
            width: 24px;
            height: 24px;
            border: 3px solid #343a40;
            border-top: 3px solid #4a90e2;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-left: 10px;
            vertical-align: middle;
        }
        @keyframes spin {
            0% { transform: rotate(0deg);}
            100% { transform: rotate(360deg);}
        }
        .hidden { display: none; }
        .section-highlight {
            animation: highlight 1s;
            box-shadow: 0 0 10px 2px #4a90e2;
        }
        @keyframes highlight {
            0% { box-shadow: 0 0 0 0 #4a90e2; }
            100% { box-shadow: 0 0 10px 2px #4a90e2; }
        }
    </style>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand mx-auto" href="#">Colorful Moves</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-center" id="navbarNavDropdown">
                <ul class="navbar-nav center-links">
                    <li class="nav-item"><a class="nav-link nav-scroll" href="#find-contracts" data-target="#find-contracts">Find Contracts</a></li>
                    <li class="nav-item"><a class="nav-link nav-scroll" href="#submit-proposal" data-target="#submit-proposal">Submit Proposal</a></li>
                    <li class="nav-item"><a class="nav-link nav-scroll" href="#local-subcontractors" data-target="#local-subcontractors">Local Subcontractors</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Portals
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdownMenuLink">
                            <li><a class="dropdown-item portal-tab-link" href="#" data-tab="vendor">Vendor Portal</a></li>
                            <li><a class="dropdown-item portal-tab-link" href="#" data-tab="admin">Admin Portal</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mb-5">
        <section id="find-contracts" class="mb-5 center-section">
            <h2>Find Contracts</h2>
            <div class="input-group mb-2 justify-content-center" style="max-width:500px;margin:auto;">
                <input type="text" id="contract-search" class="form-control" placeholder="Search for contracts...">
                <button id="search-contracts" class="btn btn-outline-primary">Search</button>
                <span id="contract-spinner" class="spinner hidden"></span>
            </div>
            <div id="contract-results"></div>
        </section>

        <section id="submit-proposal" class="mb-5 center-section">
            <h2>Submit Proposal</h2>
            <form id="proposal-form" class="mb-2" style="max-width:500px;margin:auto;">
                <div class="mb-2">
                    <input type="text" name="name" class="form-control mb-2" placeholder="Your Name" required>
                    <input type="email" name="email" class="form-control mb-2" placeholder="Your Email" required>
                    <textarea name="proposal" class="form-control mb-2" placeholder="Your Proposal" required></textarea>
                </div>
                <button type="submit" class="btn btn-success">Send Proposal</button>
                <span id="proposal-spinner" class="spinner hidden"></span>
            </form>
            <div id="proposal-status"></div>
        </section>

        <section id="local-subcontractors" class="mb-5 center-section">
            <h2>Local Subcontractors</h2>
            <button id="refresh-subcontractors" class="btn btn-outline-secondary mb-2">Refresh List</button>
            <span id="subcontractor-spinner" class="spinner hidden"></span>
            <div id="subcontractor-list"></div>
        </section>

        <!-- Portals Tabbed Section -->
        <section id="portals-tabs" class="mb-5 center-section">
            <ul class="nav nav-tabs justify-content-center" id="portalTab" role="tablist" style="margin:auto;">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="vendor-tab" data-bs-toggle="tab" data-bs-target="#vendor-portal" type="button" role="tab" aria-controls="vendor-portal" aria-selected="true">Vendor Portal</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="admin-tab" data-bs-toggle="tab" data-bs-target="#admin-portal" type="button" role="tab" aria-controls="admin-portal" aria-selected="false">Admin Portal</button>
                </li>
            </ul>
            <div class="tab-content border border-top-0 p-3" id="portalTabContent" style="max-width:500px;margin:auto;">
                <div class="tab-pane fade show active" id="vendor-portal" role="tabpanel" aria-labelledby="vendor-tab">
                    <h2>Vendor Portal</h2>
                    <p>Access vendor documentation and performance tracking.</p>
                    <a href="vendor-portal.html" class="btn btn-primary">Go to Vendor Portal</a>
                </div>
                <div class="tab-pane fade" id="admin-portal" role="tabpanel" aria-labelledby="admin-tab">
                    <h2>Admin Portal</h2>
                    <p>Access admin documentation and performance tracking.</p>
                    <a href="admin-portal.html" class="btn btn-primary">Go to Admin Portal</a>
                </div>
            </div>
        </section>
    </main>

    <!-- Fixed Footer with Chat AI Assistant -->
    <footer class="fixed-footer py-3">
        <div class="container" id="chat-assistant-container">
            <div class="d-flex justify-content-between align-items-center">
                <span>&copy; 2023 Colorful Moves. All rights reserved.</span>
                <button id="chat-toggle" class="btn btn-light btn-sm ms-2">Chat AI</button>
            </div>
            <div id="chat-assistant" style="display:none;">
                <div id="chat-messages" class="mb-2"></div>
                <form id="chat-form" autocomplete="off" class="d-flex">
                    <input type="text" id="chat-input" class="form-control me-2" placeholder="Ask me anything..." required />
                    <button type="submit" id="chat-send" class="btn btn-success">Send</button>
                    <span id="chat-spinner" class="spinner hidden"></span>
                </form>
            </div>
        </div>
    </footer>

    <script>
        // Centered smooth scroll for nav links
        $('.nav-scroll').on('click', function(e) {
            e.preventDefault();
            const target = $($(this).data('target'));
            if (target.length) {
                $('.section-highlight').removeClass('section-highlight');
                target.addClass('section-highlight');
                $('html, body').animate({
                    scrollTop: target.offset().top - 70
                }, 500, function() {
                    setTimeout(() => target.removeClass('section-highlight'), 1200);
                });
            }
        });

        // Toggle chat assistant visibility
        $('#chat-toggle').on('click', function() {
            $('#chat-assistant').toggle();
        });

        // Dynamic contract search (simulate AJAX)
        $('#search-contracts').on('click', function() {
            const query = $('#contract-search').val().trim();
            $('#contract-results').empty();
            $('#contract-spinner').removeClass('hidden');
            setTimeout(function() {
                $('#contract-spinner').addClass('hidden');
                if (!query) {
                    $('#contract-results').html('<em>Please enter a search term.</em>');
                } else {
                    // Add dynamic contract cards
                    $('#contract-results').html(
                        `<div class="row justify-content-center">
                            <div class="col-md-5 mb-3">
                                <div class="card shadow-sm">
                                    <div class="card-body">
                                        <h5 class="card-title">Painting Contract A</h5>
                                        <p class="card-text">Location: Downtown</p>
                                        <button class="apply-btn btn btn-outline-primary btn-sm">Apply</button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-5 mb-3">
                                <div class="card shadow-sm">
                                    <div class="card-body">
                                        <h5 class="card-title">Renovation Contract B</h5>
                                        <p class="card-text">Location: Uptown</p>
                                        <button class="apply-btn btn btn-outline-primary btn-sm">Apply</button>
                                    </div>
                                </div>
                            </div>
                        </div>`
                    );
                }
            }, 900);
        });

        // Apply button for contracts (dynamic event)
        $(document).on('click', '.apply-btn', function() {
            $(this).prop('disabled', true).text('Applied!');
            $(this).closest('.card').addClass('section-highlight');
            setTimeout(() => $(this).closest('.card').removeClass('section-highlight'), 1200);
        });

        // Proposal form AJAX simulation
        $('#proposal-form').on('submit', function(e) {
            e.preventDefault();
            $('#proposal-status').empty();
            $('#proposal-spinner').removeClass('hidden');
            setTimeout(function() {
                $('#proposal-spinner').addClass('hidden');
                $('#proposal-status').html('<span class="text-success">Proposal submitted successfully!</span>');
                $('#proposal-form')[0].reset();
            }, 1200);
        });

        // Dynamic subcontractor list (simulate AJAX)
        function loadSubcontractors() {
            $('#subcontractor-list').empty();
            $('#subcontractor-spinner').removeClass('hidden');
            setTimeout(function() {
                $('#subcontractor-spinner').addClass('hidden');
                $('#subcontractor-list').html(
                    `<div class="row justify-content-center">
                        <div class="col-md-5 mb-3">
                            <div class="card shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title">Jane Doe</h5>
                                    <p class="card-text">Electrician</p>
                                    <button class="contact-btn btn btn-outline-secondary btn-sm">Contact</button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-5 mb-3">
                            <div class="card shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title">John Smith</h5>
                                    <p class="card-text">Plumber</p>
                                    <button class="contact-btn btn btn-outline-secondary btn-sm">Contact</button>
                                </div>
                            </div>
                        </div>
                    </div>`
                );
            }, 800);
        }
        $('#refresh-subcontractors').on('click', loadSubcontractors);
        $(loadSubcontractors);

        // Contact button for subcontractors
        $(document).on('click', '.contact-btn', function() {
            $(this).prop('disabled', true).text('Contacted!');
            $(this).closest('.card').addClass('section-highlight');
            setTimeout(() => $(this).closest('.card').removeClass('section-highlight'), 1200);
        });

        // Chat AI Assistant with loading spinner
        $('#chat-form').on('submit', function(e) {
            e.preventDefault();
            const userMsg = $('#chat-input').val().trim();
            if (!userMsg) return;
            $('#chat-messages').append('<div class="chat-message user">You: ' + $('<div>').text(userMsg).html() + '</div>');
            $('#chat-input').val('');
            $('#chat-messages').scrollTop($('#chat-messages')[0].scrollHeight);
            $('#chat-spinner').removeClass('hidden');

            setTimeout(function() {
                let aiResponse = "I'm your AI assistant. How can I help you?";
                if (/contract|proposal|subcontractor|vendor|admin/i.test(userMsg)) {
                    aiResponse = "Let me help you with information about " + userMsg + ".";
                }
                $('#chat-messages').append('<div class="chat-message ai">AI: ' + $('<div>').text(aiResponse).html() + '</div>');
                $('#chat-messages').scrollTop($('#chat-messages')[0].scrollHeight);
                $('#chat-spinner').addClass('hidden');
            }, 700);
        });

        // Navbar dropdown links to switch tabs dynamically and highlight
        $('.portal-tab-link').on('click', function(e) {
            e.preventDefault();
            const tab = $(this).data('tab');
            if(tab === 'vendor') {
                $('#vendor-tab').tab('show');
                $('#vendor-portal').addClass('section-highlight');
                $('html, body').animate({
                    scrollTop: $('#portals-tabs').offset().top - 70
                }, 400, function() {
                    setTimeout(() => $('#vendor-portal').removeClass('section-highlight'), 1200);
                });
            } else if(tab === 'admin') {
                $('#admin-tab').tab('show');
                $('#admin-portal').addClass('section-highlight');
                $('html, body').animate({
                    scrollTop: $('#portals-tabs').offset().top - 70
                }, 400, function() {
                    setTimeout(() => $('#admin-portal').removeClass('section-highlight'), 1200);
                });
            }
        });
    </script>
</body>
</html>